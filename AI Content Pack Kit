</div><div id="toast" class="toast"></div>
<script>
const CONFIG = {"slug": "ai-content-pack-v3-final", "title": "AI Content Pack Kit", "mark": "CP", "price": "$39", "clientPrice": "$149\u2013$699", "hero": "Generate complete content packs.", "tagline": "Create the actual 30-day content calendar, captions, reel scripts, story prompts, and client-ready content brief.", "productName": "30-day content pack", "businessTypes": ["med spa", "barber shop", "gym", "coffee shop", "boutique", "restaurant", "real estate agent", "cleaning company", "photographer", "personal trainer"], "needs": ["inconsistent posting", "weak captions", "no reel ideas", "no monthly content plan", "low engagement", "boring social page"], "styles": ["Authority Content Calendar", "Local Hype Content Pack", "Trust Builder Content System", "Promo + Education Pack", "Before/After Content Plan"], "leadChecks": ["Has not posted recently", "Posts have weak captions", "No clear content themes", "No reels or video content", "Business has good services but poor social proof"], "angles": ["authority and education", "local trust", "behind-the-scenes", "customer proof", "before-and-after", "monthly consistency"], "ctas": ["Book now", "Send a DM", "Claim this month\u2019s offer", "Schedule a visit", "Request details"], "layouts": ["magazine brief", "calendar board", "campaign pack", "studio deck", "brand system"], "colorSets": [["#0f172a", "#2563eb", "#38bdf8"], ["#111827", "#db2777", "#f9a8d4"], ["#1e1b4b", "#7c3aed", "#c4b5fd"], ["#064e3b", "#059669", "#6ee7b7"]]};

let CURRENT_HTML = "";
let CURRENT_TEXT = "";
let CURRENT_FILENAME = CONFIG.slug + "-final-product";
function pick(a){return a[Math.floor(Math.random()*a.length)]}
function uid(){return Math.random().toString(36).slice(2,8).toUpperCase()}
function esc(s){return String(s||"").replace(/[&<>"']/g,m=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#039;"}[m]))}
function plainFromHTML(html){const d=document.createElement('div');d.innerHTML=html;return d.innerText}
function toast(m){const t=document.getElementById('toast');t.textContent=m;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),1900)}
function showSection(id,btn){
  document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  document.querySelectorAll('.nav button').forEach(b=>b.classList.remove('active'));
  if(btn)btn.classList.add('active');
  const titles={
    home:['Overview',CONFIG.tagline],
    lead:['Lead Finder','Find actual businesses through live searches and save leads.'],
    generator:['Final Product Generator','Create the actual client-ready digital product.'],
    preview:['Final Product Preview','This is the product the buyer would sell to a business.'],
    code:['Get The Product','Copy, download, or open the generated deliverable.'],
    howto:['How To Use It','Step-by-step instructions for turning the generated product into a real client deliverable.'],
    scripts:['Scripts + Follow-Up','Copy-paste outreach and closing messages.'],
    pricing:['Pricing + Selling','Package the offer clearly.'],
    delivery:['Delivery Checklist','Fulfill the service after landing a client.'],
    reviews:['Reviews + Results','Build trust without fake guarantees.'],
    faq:['FAQ','Common questions for buyers.']
  };
  document.getElementById('title').textContent=titles[id][0];
  document.getElementById('subtitle').textContent=titles[id][1];
  scrollTo({top:0,behavior:'smooth'});
}
function enc(s){return encodeURIComponent(s)}
function createLeadSearch(){
  const city=document.getElementById('leadCity').value||'your city', state=document.getElementById('leadState').value, type=document.getElementById('leadType').value, need=document.getElementById('leadNeed').value;
  const q=`${type} in ${city} ${state}`;
  const maps=`https://www.google.com/maps/search/${enc(q)}`;
  const google=`https://www.google.com/search?q=${enc(q+' '+need+' contact website')}`;
  const yelp=`https://www.yelp.com/search?find_desc=${enc(type)}&find_loc=${enc(city+', '+state)}`;
  const insta=`https://www.google.com/search?q=${enc('site:instagram.com '+type+' '+city+' '+state)}`;
  document.getElementById('leadSearchOutput').innerHTML=`
  <h3>Live lead searches</h3>
  <p><strong>Target:</strong> ${esc(type)} businesses in ${esc(city)}, ${esc(state)}</p>
  <p><strong>Opportunity to look for:</strong> ${esc(need)}</p>
  <div class="miniBox"><strong>Search phrase:</strong><br>${esc(q+' '+need)}</div>
  <div class="lead-actions">
    <a class="btn primary small" href="${maps}" target="_blank">Open Google Maps</a>
    <a class="btn small" href="${google}" target="_blank">Open Google Search</a>
    <a class="btn small" href="${yelp}" target="_blank">Open Yelp</a>
    <a class="btn small" href="${insta}" target="_blank">Find Instagram Pages</a>
  </div>
  <h3>What to check</h3>
  <ul>${CONFIG.leadChecks.map(x=>`<li>${esc(x)}</li>`).join('')}</ul>
  <p>Open the live search, pick real businesses, then paste the best ones into the lead pipeline.</p>`;
}
function getLeads(){return JSON.parse(localStorage.getItem(CONFIG.slug+'_leads')||'[]')}
function renderLeads(){const box=document.getElementById('leadList');const leads=getLeads();box.innerHTML=leads.length?leads.map((l,i)=>`<div class="lead-row"><strong>${esc(l.name)}</strong><br><span class="muted">${esc(l.contact||'No contact saved')}</span><br><span class="muted">${esc(l.note||'')}</span><br>${l.link?`<a class="btn small" target="_blank" href="${esc(l.link)}">Open Link</a>`:''} <button class="btn small" onclick="removeLead(${i})">Remove</button></div>`).join(''):'<p class="muted">No leads saved yet.</p>'}
function saveLead(){const leads=getLeads();leads.push({name:document.getElementById('saveName').value||'New Lead',link:document.getElementById('saveLink').value,contact:document.getElementById('saveContact').value,note:document.getElementById('saveNote').value});localStorage.setItem(CONFIG.slug+'_leads',JSON.stringify(leads));renderLeads();toast('Lead saved.')}
function removeLead(i){const leads=getLeads();leads.splice(i,1);localStorage.setItem(CONFIG.slug+'_leads',JSON.stringify(leads));renderLeads()}
function getDetails(){return {
  name:document.getElementById('bizName').value||'Example Business',
  loc:document.getElementById('bizLocation').value||'your city',
  type:document.getElementById('bizType').value,
  need:document.getElementById('bizNeed').value,
  tone:document.getElementById('tone').value,
  style:document.getElementById('style').value,
  notes:document.getElementById('notes').value,
  angle:pick(CONFIG.angles), cta:pick(CONFIG.ctas), id:uid(),
  color:pick(CONFIG.colorSets), layout:pick(CONFIG.layouts)
}}
function setProduct(html, summary, filename){
  CURRENT_HTML = html;
  CURRENT_TEXT = plainFromHTML(html);
  CURRENT_FILENAME = filename || CONFIG.slug + "-final-product";
  document.getElementById('finalPreview').innerHTML = html;
  document.getElementById('codeOutput').textContent = html;
  document.getElementById('summaryOutput').innerHTML = summary;
  showSection('preview',document.querySelector('[onclick*=preview]'));
}
function copyFinalText(){if(!CURRENT_TEXT){toast('Generate product first.');return}navigator.clipboard.writeText(CURRENT_TEXT);toast('Final product text copied.')}
function copyFinalHTML(){if(!CURRENT_HTML){toast('Generate product first.');return}navigator.clipboard.writeText(CURRENT_HTML);toast('HTML/product code copied.')}
function downloadFinalHTML(){if(!CURRENT_HTML){toast('Generate product first.');return}const blob=new Blob([CURRENT_HTML],{type:'text/html'});const url=URL.createObjectURL(blob);const a=document.createElement('a');a.href=url;a.download=CURRENT_FILENAME+'.html';a.click();URL.revokeObjectURL(url);toast('HTML file downloaded.')}
function downloadFinalTXT(){if(!CURRENT_TEXT){toast('Generate product first.');return}const blob=new Blob([CURRENT_TEXT],{type:'text/plain'});const url=URL.createObjectURL(blob);const a=document.createElement('a');a.href=url;a.download=CURRENT_FILENAME+'.txt';a.click();URL.revokeObjectURL(url);toast('Text file downloaded.')}
function openFinalNewTab(){if(!CURRENT_HTML){toast('Generate product first.');return}const w=window.open();w.document.open();w.document.write(CURRENT_HTML);w.document.close();}
function downloadWebsiteIndex(){downloadFinalHTML()}


function generateProduct(){
  const d=getDetails();
  const themes=["Education","Trust","Behind the Scenes","Service Spotlight","FAQ","Customer Proof","Offer/CTA","Local Community","Before/After","Quick Tip","Myth Busting","Testimonial"];
  const contentTypes=["Carousel","Reel","Story","Static Post","Short Video","Before/After"];
  let days = Array.from({length:30},(_,i)=>`<tr><td>Day ${i+1}</td><td>${pick(contentTypes)}</td><td>${pick(themes)}</td><td>${esc(d.name)} ${pick(["educates customers about","shows the process behind","answers a common question about","highlights why customers choose","breaks down a mistake around"])} ${esc(d.type)}.</td><td>${esc(d.cta)}</td></tr>`).join('');
  let captions = Array.from({length:14},()=>`<li>${esc(pick(["Not sure where to start?","Here’s one thing most customers miss:","A small detail that makes a big difference:","Before you book, check this:","Most people wait too long to ask this:"]))} ${esc(d.name)} helps ${esc(d.loc)} customers with ${esc(d.need)}. ${esc(d.cta)}.</li>`).join('');
  let reels = Array.from({length:7},(_,i)=>`<div class="docbox"><h3>Reel ${i+1}: ${pick(["3 mistakes customers make","Behind the scenes","Before you choose","What to expect","Common question answered","Local customer tip","A quick transformation"])}</h3><p><strong>Hook:</strong> If you need a ${esc(d.type)} in ${esc(d.loc)}, watch this first.</p><p><strong>Shots:</strong> ${pick(["team/process/proof/CTA","before shot/process/result/CTA","problem/explanation/solution/CTA","customer question/answer/proof/CTA"])}</p><p><strong>CTA:</strong> ${esc(d.cta)}</p></div>`).join('');
  CURRENT_HTML = `<div class="final-doc"><span class="pill">${esc(d.style)} · ${esc(d.layout)}</span><h1>30-Day Content Pack for ${esc(d.name)}</h1><p>This is a complete client-ready content system for a ${esc(d.type)} in ${esc(d.loc)} focused on ${esc(d.angle)} and ${esc(d.need)}.</p><h2>Content Pillars</h2><ul><li>Trust + proof</li><li>Service education</li><li>Local authority</li><li>FAQs and objections</li><li>Offers and CTAs</li></ul><h2>30-Day Calendar</h2><table border="1" cellspacing="0" cellpadding="8" style="width:100%;border-collapse:collapse"><tr><th>Day</th><th>Format</th><th>Theme</th><th>Post Idea</th><th>CTA</th></tr>${days}</table><h2>Caption Bank</h2><ol>${captions}</ol><h2>Reel Scripts</h2>${reels}<h2>Story Prompts</h2><ul><li>Poll: What do you care about most when choosing a ${esc(d.type)}?</li><li>Question box: Ask us anything about ${esc(d.type)} services.</li><li>Before/after proof post.</li><li>Customer reminder with CTA: ${esc(d.cta)}.</li></ul><h2>Monthly Upsell</h2><p>Offer this as a monthly content support package for $299–$699/month depending on post volume and design quality.</p></div>`;
  setProduct(CURRENT_HTML, `<h2>Content pack generated for ${esc(d.name)}</h2><div class="miniBox"><strong>Variation ID:</strong> ${d.id}<br><strong>Layout:</strong> ${esc(d.layout)}<br><strong>Angle:</strong> ${esc(d.angle)}</div><p>The 30-day calendar, captions, reel scripts, story prompts, and upsell plan are ready.</p>`, CONFIG.slug+"-"+d.id);
  toast('Content pack generated.');
}

renderLeads();
</script></body></html>
