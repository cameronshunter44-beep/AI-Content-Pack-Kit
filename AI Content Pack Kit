.preview-frame{width:100%;height:680px;border:0;border-radius:22px;background:#fff;box-shadow:0 24px 70px rgba(0,0,0,.28)}
.final-doc{background:#fff;color:#111827;border-radius:22px;padding:34px;box-shadow:0 24px 70px rgba(0,0,0,.25);max-width:1020px;margin:auto}
.final-doc h1,.final-doc h2,.final-doc h3{color:#0f172a;margin:14px 0 8px}.final-doc p,.final-doc li{color:#334155;line-height:1.6}.final-doc ul,.final-doc ol{padding-left:22px}.final-doc .docbox{border:1px solid #e2e8f0;background:#f8fafc;border-radius:16px;padding:14px;margin:10px 0}.final-doc .pill{display:inline-flex;background:#e0f2fe;color:#0369a1;border-radius:999px;padding:6px 10px;font-weight:900;font-size:12px}
.code-box{white-space:pre-wrap;background:#020617;border:1px solid rgba(255,255,255,.12);border-radius:18px;padding:16px;color:#dbeafe;font-size:12.5px;line-height:1.5;max-height:580px;overflow:auto}
.checklist{display:grid;gap:10px;margin-top:12px}.check{border:1px solid var(--line);background:rgba(255,255,255,.035);border-radius:15px;padding:12px 13px;color:#dbeafe;font-size:14px;line-height:1.45}
.script{white-space:pre-wrap;background:rgba(2,8,20,.70);border:1px solid var(--line);border-radius:18px;padding:15px;color:#dbeafe;font-size:13.5px;line-height:1.58}
.lead-list{display:grid;gap:10px}.lead-row{border:1px solid var(--line);border-radius:16px;background:rgba(255,255,255,.035);padding:12px}
.review{border:1px solid var(--line);border-radius:18px;background:rgba(255,255,255,.035);padding:14px}.stars{color:#fde68a;letter-spacing:2px;margin-bottom:7px}.review footer{display:flex;justify-content:space-between;gap:10px;color:#93a4bd;font-size:12px;margin-top:10px}
.faq{border:1px solid var(--line);border-radius:18px;background:rgba(255,255,255,.035);padding:16px}.faq h4{margin-bottom:8px}
.footer{margin:18px 0 0;text-align:center;color:#6f8099;font-size:12px}.toast{position:fixed;right:22px;bottom:22px;z-index:90;border:1px solid rgba(75,216,255,.18);border-radius:16px;background:linear-gradient(135deg,rgba(75,216,255,.18),rgba(139,92,246,.18));box-shadow:var(--shadow);padding:12px 14px;opacity:0;transform:translateY(14px);transition:.25s}.toast.show{opacity:1;transform:none}
@media(max-width:1060px){.app{grid-template-columns:1fr}.sidebar{position:relative;height:auto}.hero-content,.grid-2,.grid-3,.grid-4,.form-grid{grid-template-columns:1fr}.hero h1{font-size:40px}.topbar,.section-head{flex-direction:column;align-items:flex-start}.main{padding:16px}.preview-frame{height:560px}}
</style></head>
